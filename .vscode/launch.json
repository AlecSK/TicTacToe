{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "TicTacToe (backend + frontend)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: TicTacToe.API",
      "program": "${workspaceFolder}/backend/src/TicTacToe.API/bin/Debug/net8.0/TicTacToe.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/src/TicTacToe.API",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_HOSTINGSTARTUPASSEMBLIES": "Microsoft.AspNetCore.SpaProxy",
        "ASPNETCORE_URLS": "http://localhost:5000"
      }
    }
  ]
}
